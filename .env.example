# =============================================================================
# Chronos Narrative Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# All variables are prefixed CHRONOS_ for namespace isolation.
# =============================================================================

# --- Ollama (LLM Backend) ---
CHRONOS_OLLAMA_URL=http://localhost:11434
CHRONOS_OLLAMA_MODEL=llama3.1:8b

# --- LLM Defaults ---
CHRONOS_LLM_PROVIDER=ollama
CHRONOS_LLM_TEMPERATURE=30
CHRONOS_LLM_MAX_TOKENS=2048
CHRONOS_LLM_TOP_P=90
CHRONOS_LLM_COMPLIANCE_TOKENS=1024
CHRONOS_LLM_NARRATIVE_TIMEOUT=120
CHRONOS_LLM_COMPLIANCE_TIMEOUT=60

# --- Offline Fallback ---
# When true, if the LLM provider is unreachable, a template-based
# narrative is generated instead of showing an error.
CHRONOS_LLM_FALLBACK=true

# --- Whisper (Transcription) ---
CHRONOS_TRANSCRIBER_PROVIDER=whisper
CHRONOS_WHISPER_MODEL=large-v3-turbo
CHRONOS_WHISPER_DEVICE=cuda
CHRONOS_WHISPER_COMPUTE_TYPE=int8_float16
CHRONOS_WHISPER_CPU_THREADS=4
CHRONOS_WHISPER_BATCH_SIZE=4
CHRONOS_WHISPER_BEAM_SIZE=5
CHRONOS_WHISPER_VAD_SILENCE_MS=300
CHRONOS_WHISPER_VAD_SPEECH_PAD_MS=300
CHRONOS_WHISPER_VAD_THRESHOLD=0.30
CHRONOS_WHISPER_VAD_MIN_SPEECH_MS=200
CHRONOS_WHISPER_AUDIO_PREPROCESS=true
CHRONOS_WHISPER_NOISE_REDUCE_STRENGTH=0.75
CHRONOS_WHISPER_NOISE_METHOD=noisereduce
CHRONOS_WHISPER_DEEPFILTER_ATTEN=
CHRONOS_WHISPER_INITIAL_PROMPT=The following is a law enforcement body camera recording. Officer, dispatch, suspect, traffic stop, investigation, patrol, squad, domestic, battery, OWI, PBT, Miranda.
CHRONOS_WHISPER_WORD_TIMESTAMPS=true
CHRONOS_WHISPER_TRANSCRIPT_CORRECTOR=true
CHRONOS_WHISPER_TWO_PASS=false
CHRONOS_WHISPER_TWO_PASS_QUICK_MODEL=base

# --- Advanced Transcription Features ---
# BatchedInferencePipeline: 4x faster transcription via VAD + batching (requires faster-whisper >=1.1.0)
CHRONOS_WHISPER_USE_BATCHED=true
# Forced alignment via wav2vec2: ±50ms word timestamps instead of ±500ms (requires transformers)
CHRONOS_WHISPER_ENABLE_ALIGNMENT=true
# Speaker diarization via pyannote: identifies who spoke when (requires pyannote.audio)
CHRONOS_WHISPER_ENABLE_DIARIZATION=false

# --- PDF Parser ---
CHRONOS_PDF_PARSER_PROVIDER=zuercher

# --- Prompt Limits ---
CHRONOS_MAX_STYLE_EXAMPLES=5
CHRONOS_MAX_TRANSCRIPT_CHARS=4000
CHRONOS_MAX_STYLE_EXAMPLE_CHARS=1500
CHRONOS_MAX_CAD_TEXT_CHARS=8000
CHRONOS_MAX_TOTAL_PROMPT_CHARS=12000

# --- Infrastructure & Architecture ---
CHRONOS_DB_URL=postgresql://chronos_user:chronos_password@localhost:5432/chronos_db
CHRONOS_REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# AUTH_MODE can be 'local' or 'ldap'
CHRONOS_AUTH_MODE=local
CHRONOS_LDAP_SERVER=ldap://localhost:389
CHRONOS_LDAP_BASE_DN=dc=example,dc=com
CHRONOS_LDAP_GROUP_ADMIN=CN=ChronosAdmins,OU=Groups,DC=example,DC=com
CHRONOS_LDAP_GROUP_SUPERVISOR=CN=ChronosSupervisors,OU=Groups,DC=example,DC=com
CHRONOS_LDAP_GROUP_PATROL=CN=ChronosPatrol,OU=Groups,DC=example,DC=com

# --- File Paths ---
CHRONOS_TEMP_DIR=temp_processing
CHRONOS_COMPLETED_DIR=completed_reports
CHRONOS_PROFILES_DIR=officer_profiles
CHRONOS_CATEGORIES_FILE=custom_categories.txt

# --- Upload Limits ---
CHRONOS_MAX_UPLOAD_GB=4

# --- Pipeline & GPU ---
CHRONOS_PIPELINE_WORKERS=2
CHRONOS_VRAM_BUDGET_FRACTION=85

# --- Department Letterhead ---
CHRONOS_DEPT_NAME=Sheriff's Department
CHRONOS_DEPT_ADDRESS=123 Main Street
CHRONOS_DEPT_CITY=Anytown, WI 12345
CHRONOS_DEPT_PHONE=(555) 123-4567
CHRONOS_DEPT_LOGO=

# --- Session ---
CHRONOS_SESSION_TIMEOUT=1800

# --- Data Retention (0 = disabled) ---
CHRONOS_DATA_RETENTION_DAYS=0

# --- Evidence Locker ---
CHRONOS_EVIDENCE_DIR=evidence_storage
CHRONOS_EVIDENCE_MAX_FILES=100

# --- Spell Check ---
CHRONOS_SPELL_CHECK=true

# --- Digital Signature ---
CHRONOS_SIGNATURE_ENABLED=true

# --- REST API ---
CHRONOS_API_KEY=
CHRONOS_API_BIND=127.0.0.1
CHRONOS_API_PORT=8765

# --- Database ---
CHRONOS_DB_TIMEOUT=30

# --- Security ---
# HMAC key for audit chain integrity. If left empty, a key is generated
# automatically and persisted to .chronos_hmac_key next to the database.
CHRONOS_AUDIT_HMAC_KEY=

# Master encryption key for evidence files at rest. If left empty, a
# temporary key is generated on each startup (sessions are not persistent).
CHRONOS_ENCRYPTION_KEY=
